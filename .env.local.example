# ══════════════════════════════════════════════════════════════════════════════
#  OUTLAWS SYNDICATE — Variables de entorno
#  Copia como .env.local para desarrollo local.
#  En Vercel: Settings > Environment Variables (copiar cada valor).
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase ───────────────────────────────────────────────────────────────────
# Obtén estos valores en: https://supabase.com/dashboard > tu proyecto > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── Discord OAuth App ──────────────────────────────────────────────────────────
# Obtén estos valores en https://discord.com/developers/applications
# > Tu App > OAuth2 > Client ID / Client Secret
# IMPORTANTE: En "Redirects" añade:
#   - http://localhost:3000/api/auth/callback/discord  (desarrollo)
#   - https://tu-app.vercel.app/api/auth/callback/discord  (produccion)
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here

# ── NextAuth ───────────────────────────────────────────────────────────────────
# Genera con: openssl rand -base64 32
# En produccion, pon la URL de tu dominio Vercel (sin / al final)
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# ── Discord Server (Guild) ─────────────────────────────────────────────────────
# ID del servidor de Discord de Outlaws Syndicate
DISCORD_GUILD_ID=your_guild_id_here

# ── Discord Bot Token ──────────────────────────────────────────────────────────
# En Discord Developers > tu app > Bot > Reset Token > copiar.
# El bot debe estar invitado al servidor con permiso "Manage Events".
# URL de invitacion (reemplaza CLIENT_ID):
# https://discord.com/api/oauth2/authorize?client_id=TU_CLIENT_ID&permissions=8589934592&scope=bot
DISCORD_BOT_TOKEN=your_bot_token_here

# ── IDs de Roles de Discord ────────────────────────────────────────────────────
# En Discord: Ajustes del servidor > Roles > clic derecho > Copiar ID
DISCORD_ROLE_COMANDANTE=role_id_here
DISCORD_ROLE_GENERAL=role_id_here
DISCORD_ROLE_CAPITAN=role_id_here
DISCORD_ROLE_TENIENTE=role_id_here
DISCORD_ROLE_SOLDADO=role_id_here
DISCORD_ROLE_RECLUTA=role_id_here
DISCORD_ROLE_ALIADO=role_id_here
